code = "shader_type canvas_item;
render_mode blend_mix;


// Varyings
varying vec2 var_vertex;

uniform vec2 Movement = vec2(0.000000, 0.000000);



void vertex() {
// Input:2
	vec2 n_out2p0 = VERTEX;


// Vector2Parameter:4
	vec2 n_out4p0 = Movement;


// VectorOp:3
	vec2 n_out3p0 = n_out2p0 + n_out4p0;


// VaryingSetter:5
	var_vertex = n_out3p0;


}

void fragment() {
// VaryingGetter:10
	vec2 n_out10p0 = var_vertex;


// Output:0
	COLOR.rgb = vec3(n_out10p0, 0.0);


}
"
