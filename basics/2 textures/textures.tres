code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D tex_frg_7;
uniform sampler2D tex_frg_5;
uniform sampler2D tex_frg_3;



void fragment() {
// Input:10
	vec4 n_out10p0 = COLOR;


// Texture2D:7
	vec4 n_out7p0 = texture(tex_frg_7, UV);


// Texture2D:5
	vec4 n_out5p0 = texture(tex_frg_5, UV);


// Step:6
	float n_in6p1 = 0.38500;
	float n_out6p0 = step(n_out5p0.x, n_in6p1);


// Mix:11
	vec3 n_out11p0 = mix(vec3(n_out10p0.xyz), vec3(n_out7p0.xyz), vec3(n_out6p0));


// Texture2D:3
	vec4 n_out3p0 = texture(tex_frg_3, UV);


// FloatFunc:4
	float n_out4p0 = 1.0 - n_out3p0.x;


// Output:0
	COLOR.rgb = n_out11p0;
	COLOR.a = n_out4p0;


}
"
